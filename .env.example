# ─────────────────────────────────────────────────────────────────────
# AI Trading Brain — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────

# Active broker: zerodha | dhan | angelone
ACTIVE_BROKER=zerodha

# ── Zerodha KiteConnect ───────────────────────────────────────────────
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token

# ── Dhan HQ ──────────────────────────────────────────────────────────
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token
# Get from: https://dhan.co → My Profile → API → Create App

# ── Telegram Alerts (optional) ───────────────────────────────────────
# Leave blank to disable Telegram; alerts will log only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading Mode ──────────────────────────────────────────────────────
# PAPER_TRADING=true  → simulate all orders (safe default)
# PAPER_TRADING=false → live order placement via Dhan API
PAPER_TRADING=true
USE_LIVE_DATA=true

# ── Pilot Capital ─────────────────────────────────────────────────────
PILOT_CAPITAL=20000          # ₹ starting capital
PILOT_RISK_PCT=0.005         # 0.5% per trade → ₹100 at ₹20k
PILOT_MAX_TRADES=2
PILOT_DAILY_LOSS_PCT=0.02    # 2% daily loss limit → ₹400/day

# ── AngelOne SmartAPI ─────────────────────────────────────────────────
ANGELONE_API_KEY=your_angelone_api_key
ANGELONE_CLIENT_ID=your_angelone_client_id
ANGELONE_PASSWORD=your_angelone_password
ANGELONE_TOTP_SECRET=your_angelone_totp_secret_base32

# ── Capital & Risk ────────────────────────────────────────────────────
TOTAL_CAPITAL=1000000

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
